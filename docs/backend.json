
{
  "entities": {
    "Host": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Host",
      "type": "object",
      "description": "Represents a host in the ChanloPay system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Host entity."
        },
        "email": {
          "type": "string",
          "description": "Email address of the host.",
          "format": "email"
        },
        "name": {
          "type": "string",
          "description": "Full name of the host."
        },
        "mobile": {
          "type": "string",
          "description": "Mobile number of the host."
        },
        "upi": {
          "type": "string",
          "description": "UPI ID of the host for withdrawals."
        },
        "registrationDate": {
          "type": "string",
          "description": "Date and time when the host registered.",
          "format": "date-time"
        },
        "policiesAccepted": {
          "type": "boolean",
          "description": "Whether the host has accepted the Privacy Policy and Terms."
        },
        "policiesAcceptedAt": {
          "type": "string",
          "description": "Timestamp of policy acceptance.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "registrationDate"
      ]
    },
    "Event": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Event",
      "type": "object",
      "description": "Represents an event for which payments are tracked.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Event entity."
        },
        "hostId": {
          "type": "string",
          "description": "Reference to Host."
        },
        "eventName": {
          "type": "string",
          "description": "Name of the event."
        },
        "eventDate": {
          "type": "string",
          "description": "Date and time of the event.",
          "format": "date-time"
        },
        "location": {
          "type": "string",
          "description": "Location of the event."
        },
        "qrCode": {
          "type": "string",
          "description": "QR code associated with the event."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the event was created.",
          "format": "date-time"
        },
        "withdrawalRequested": {
          "type": "boolean",
          "description": "Whether a withdrawal has been requested for this event."
        },
        "status": {
          "type": "string",
          "enum": ["Live", "Completed"],
          "description": "Current status of the event."
        }
      },
      "required": [
        "id",
        "hostId",
        "eventName",
        "eventDate",
        "qrCode",
        "location"
      ]
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "description": "Represents a transaction made during an event.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Transaction entity."
        },
        "eventId": {
          "type": "string",
          "description": "Reference to Event."
        },
        "transactionDate": {
          "type": "string",
          "description": "Date and time of the transaction.",
          "format": "date-time"
        },
        "amount": {
          "type": "number",
          "description": "Amount of the transaction."
        },
        "paymentMethod": {
          "type": "string",
          "description": "Payment method used."
        },
        "name": {
          "type": "string",
          "description": "Name of the payer."
        },
        "village": {
          "type": "string",
          "description": "Village of the payer."
        },
        "status": {
          "type": "string",
          "description": "Success, Pending, or Failed."
        },
        "type": {
          "type": "string",
          "description": "Gift, Donation, or Service."
        }
      },
      "required": [
        "id",
        "eventId",
        "transactionDate",
        "amount",
        "status"
      ]
    },
    "WithdrawalRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WithdrawalRequest",
      "type": "object",
      "description": "Represents a request by a host to withdraw event funds.",
      "properties": {
        "id": {
          "type": "string"
        },
        "hostId": {
          "type": "string"
        },
        "eventId": {
          "type": "string"
        },
        "eventName": {
          "type": "string"
        },
        "totalAmount": {
          "type": "number"
        },
        "platformFee": {
          "type": "number"
        },
        "payoutAmount": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": [
            "Pending Review",
            "Processing",
            "Completed",
            "Rejected"
          ]
        },
        "requestDate": {
          "type": "string",
          "format": "date-time"
        },
        "hostUpi": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "hostId",
        "eventId",
        "totalAmount",
        "platformFee",
        "payoutAmount",
        "status",
        "requestDate"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/hosts/{hostId}",
        "definition": {
          "entityName": "Host",
          "schema": {
            "$ref": "#/backend/entities/Host"
          },
          "description": "Stores host profiles."
        }
      },
      {
        "path": "/hosts/{hostId}/events/{eventId}",
        "definition": {
          "entityName": "Event",
          "schema": {
            "$ref": "#/backend/entities/Event"
          },
          "description": "Stores events."
        }
      },
      {
        "path": "/hosts/{hostId}/events/{eventId}/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "schema": {
            "$ref": "#/backend/entities/Transaction"
          },
          "description": "Stores transactions for an event."
        }
      },
      {
        "path": "/withdrawals/{withdrawalId}",
        "definition": {
          "entityName": "WithdrawalRequest",
          "schema": {
            "$ref": "#/backend/entities/WithdrawalRequest"
          },
          "description": "Stores all withdrawal requests in a flat root collection for easier administrative querying."
        }
      }
    ]
  }
}
