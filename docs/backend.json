{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        }
      },
      "required": ["email"]
    },
    "Event": {
      "title": "Event",
      "description": "Represents an event created by a user.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the event."
        },
        "location": {
          "type": "string",
          "description": "The location of the event."
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time of the event."
        },
        "qrCodeValue": {
            "type": "string",
            "description": "The value encoded in the QR code for payments."
        },
        "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the event was created."
        }
      },
      "required": ["name", "location", "date", "qrCodeValue", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a payment transaction for an event.",
      "type": "object",
      "properties": {
        "amount": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": ["Success", "Pending", "Failed"]
        },
        "type": {
          "type": "string",
          "enum": ["Gift", "Donation", "Service"]
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "date": {
            "type": "string",
            "format": "date-time"
        }
      },
      "required": ["amount", "status", "type", "name", "email", "date"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profile information."
    },
    "/users/{userId}/events/{eventId}": {
      "schema": { "$ref": "#/entities/Event" },
      "description": "Stores events created by a specific user."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Stores transactions for a specific user."
    }
  }
}
