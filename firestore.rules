
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(hostId) {
      return isSignedIn() && request.auth.uid == hostId;
    }

    /**
     * Controls access to individual Host profiles and all nested data.
     * Hierarchy: /hosts/{hostId}/events/{eventId}/transactions/{transactionId}
     */
    match /hosts/{hostId} {
      // Allow read for anyone to fetch host's UPI details for payment
      allow read: if true;
      allow write: if isOwner(hostId);

      match /events/{eventId} {
        // Allow read for guests to see event details
        allow read: if true;
        allow write: if isOwner(hostId);

        match /transactions/{transactionId} {
          // Allow guests to create their own transaction record
          allow create: if true;
          // Only host can read/update/delete transactions
          allow read, update, delete: if isOwner(hostId);
        }
      }

      match /{allPaths=**} {
        allow read, write: if isOwner(hostId);
      }
    }
  }
}
