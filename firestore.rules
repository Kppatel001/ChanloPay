rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(hostId) {
      return isSignedIn() && request.auth.uid == hostId;
    }

    // PRODUCTION SECURITY: Request Validation Helpers
    function isValidTransaction() {
      let data = request.resource.data;
      return data.amount > 0 
          && data.name.size() >= 2
          && data.village.size() >= 2
          && data.status == 'Success';
    }

    /**
     * Controls access to individual Host profiles and all nested data.
     */
    match /hosts/{hostId} {
      // Anyone can fetch host's UPI details for payment
      allow read: if true;
      allow write: if isOwner(hostId);

      match /events/{eventId} {
        // Guests can see event details
        allow read: if true;
        allow write: if isOwner(hostId);

        match /transactions/{transactionId} {
          // PRODUCTION SECURITY: Guests can create, but only if they follow strict schema
          allow create: if isValidTransaction();
          // Only host can manage transactions
          allow read, update, delete: if isOwner(hostId);
        }
      }

      match /{allPaths=**} {
        allow read, write: if isOwner(hostId);
      }
    }
  }
}
