
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(hostId) {
      return isSignedIn() && request.auth.uid == hostId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@chanlopay.com';
    }

    // PRODUCTION SECURITY: Transaction Validation
    function isValidTransaction() {
      let data = request.resource.data;
      return data.amount > 0 
          && data.name.size() >= 2
          && data.status == 'Success';
    }

    /**
     * Root Withdrawals Collection
     * Centralized for Admin review and Host tracking.
     */
    match /withdrawals/{withdrawalId} {
      // Admin can see and process everything
      allow read: if isAdmin();
      
      // Allow updates to status and processedDate (Platform Logic / Admin)
      // We allow this update even if unauthenticated to support the Server Action Firewall,
      // provided ONLY the status and date are being changed.
      allow update: if isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'processedDate']));
      
      // Platform logic (Server Actions) can create requests
      allow create: if true; 
      
      // Hosts can read their own request history
      allow read: if isSignedIn() && (resource == null || resource.data.hostId == request.auth.uid);
    }

    /**
     * Controls access to individual Host profiles and all nested data.
     */
    match /hosts/{hostId} {
      // Required for platform to fetch host's payout/identity info during withdrawal
      allow read: if true;
      allow write: if isOwner(hostId);

      match /events/{eventId} {
        // Guests can see event details to make payments
        allow read: if true;
        
        // Allow platform logic (Server Actions) to mark event as withdrawn
        // This is safe because it only affects the 'withdrawalRequested' boolean.
        allow update: if isOwner(hostId) || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['withdrawalRequested']));
        
        allow create, delete: if isOwner(hostId);

        match /transactions/{transactionId} {
          // Allow platform/guests to create verified transactions
          allow create: if isValidTransaction();
          
          // Allow reading transactions so the platform can sum totals for payouts
          allow read: if true;
          
          // Only host can modify or delete their transaction records
          allow update, delete: if isOwner(hostId);
        }
      }

      // Catch-all for other host data
      match /{allPaths=**} {
        allow read, write: if isOwner(hostId);
      }
    }
  }
}
