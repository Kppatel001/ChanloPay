
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(hostId) {
      return isSignedIn() && request.auth.uid == hostId;
    }

    /**
     * Controls access to individual Host profiles and all nested data.
     * Hierarchy: /hosts/{hostId}/events/{eventId}/transactions/{transactionId}
     */
    match /hosts/{hostId} {
      // Simplified rules to ensure host can always manage their own data
      allow read, write: if isOwner(hostId);

      match /{allPaths=**} {
        allow read, write: if isOwner(hostId);
      }
    }
  }
}
