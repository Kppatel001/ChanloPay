
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(hostId) {
      return isSignedIn() && request.auth.uid == hostId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@chanlopay.com';
    }

    // PRODUCTION SECURITY: Transaction Validation
    function isValidTransaction() {
      let data = request.resource.data;
      return data.amount > 0 
          && data.name.size() >= 2
          && data.status == 'Success';
    }

    // PRODUCTION SECURITY: Withdrawal Validation
    function isValidWithdrawal() {
      let data = request.resource.data;
      return data.totalAmount > 0 
          && data.payoutAmount > 0
          && data.status == 'Pending Review';
    }

    /**
     * Root Withdrawals Collection
     */
    match /withdrawals/{withdrawalId} {
      // Admin can see everything
      allow read, update: if isAdmin();
      // Platform logic (Server Actions) can create
      allow create: if true; 
      // Hosts can read their own
      allow read: if isSignedIn() && (resource == null || resource.data.hostId == request.auth.uid);
    }

    /**
     * Controls access to individual Host profiles and all nested data.
     */
    match /hosts/{hostId} {
      // Anyone can fetch host's payout/identity info for verification
      allow read: if true;
      allow write: if isOwner(hostId);

      match /events/{eventId} {
        // Guests can see event details
        allow read: if true;
        // Allow platform to mark event as withdrawn during payout request
        allow update: if isOwner(hostId) || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['withdrawalRequested']));
        allow create, delete: if isOwner(hostId);

        match /transactions/{transactionId} {
          // Allow platform/guests to create verified transactions
          allow create: if isValidTransaction();
          // Only host can manage/view transaction history
          allow read, update, delete: if isOwner(hostId);
        }
      }

      // Legacy path cleanup: restrict access
      match /withdrawals/{withdrawalId} {
        allow read, write: if isOwner(hostId);
      }

      // Catch-all for other host data
      match /{allPaths=**} {
        allow read, write: if isOwner(hostId);
      }
    }
  }
}
