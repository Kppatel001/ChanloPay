rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helper functions ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(hostId) {
      return isSignedIn() && request.auth.uid == hostId;
    }

    // Platform administrators (by verified email in the auth token).
    // Keep this list in sync with ADMIN_EMAILS in src/lib/admin.ts.
    function isAdmin() {
      return isSignedIn() && request.auth.token.email in ['kartavyap43@gmail.com'];
    }

    function incoming() {
      return request.resource.data;
    }

    // A guest-created transaction must be well-formed. This is the core
    // "firewall" around payments: it rejects malformed, oversized, or
    // tampered records even though creation is open to unauthenticated guests.
    function isValidTransaction() {
      let d = incoming();
      return
        d.name is string && d.name.size() > 0 && d.name.size() <= 100 &&
        d.amount is number && d.amount > 0 && d.amount <= 1000000 &&
        d.transactionDate is string && d.transactionDate.size() <= 40 &&
        d.status is string && d.status in ['Success', 'Pending', 'Failed'] &&
        d.type is string && d.type in ['Gift', 'Donation', 'Service'] &&
        (!('village' in d) || (d.village is string && d.village.size() <= 100)) &&
        (!('mobile' in d) || (d.mobile is string && d.mobile.size() <= 20)) &&
        (!('relationship' in d) || (d.relationship is string && d.relationship.size() <= 60)) &&
        (!('blessing' in d) || (d.blessing is string && d.blessing.size() <= 500)) &&
        (!('email' in d) || (d.email is string && d.email.size() <= 200)) &&
        (!('paymentMethod' in d) || (d.paymentMethod is string && d.paymentMethod.size() <= 30)) &&
        (!('receiptQrCode' in d) || (d.receiptQrCode is string && d.receiptQrCode.size() <= 100)) &&
        d.keys().size() <= 15;
    }

    function isValidHostWrite(hostId) {
      let d = incoming();
      return
        d.id == hostId &&
        (!('name' in d) || (d.name is string && d.name.size() <= 100)) &&
        (!('mobile' in d) || (d.mobile is string && d.mobile.size() <= 20)) &&
        (!('upi' in d) || (d.upi is string && d.upi.size() <= 120)) &&
        (!('email' in d) || (d.email is string && d.email.size() <= 200));
    }

    function isValidEventWrite(hostId) {
      let d = incoming();
      return
        d.hostId == hostId &&
        d.eventName is string && d.eventName.size() > 0 && d.eventName.size() <= 120 &&
        (!('location' in d) || (d.location is string && d.location.size() <= 200));
    }

    // ---------- Host profiles and nested data ----------
    match /hosts/{hostId} {
      // A guest can fetch a specific host profile (to render the payment page),
      // but only an admin may enumerate/list all hosts.
      allow get: if true;
      allow list: if isAdmin();
      allow create, update: if isOwner(hostId) && isValidHostWrite(hostId);
      allow delete: if isOwner(hostId);

      match /events/{eventId} {
        // A guest can fetch a specific event; owner and admin can list.
        allow get: if true;
        allow list: if isOwner(hostId) || isAdmin();
        allow create, update: if isOwner(hostId) && isValidEventWrite(hostId);
        allow delete: if isOwner(hostId);

        match /transactions/{transactionId} {
          // Guests may CREATE their own valid contribution record.
          allow create: if isValidTransaction();
          // Owner and admin may read; only the owner may edit/delete.
          allow get, list: if isOwner(hostId) || isAdmin();
          allow update, delete: if isOwner(hostId);
        }
      }

      // Any other nested data: readable by owner or admin, writable by owner.
      match /{document=**} {
        allow read: if isOwner(hostId) || isAdmin();
        allow write: if isOwner(hostId);
      }
    }

    // ---------- Default deny for everything else ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
